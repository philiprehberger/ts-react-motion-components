{
  "name": "@philiprehberger/react-motion-components",
  "version": "0.1.0",
  "description": "Framer Motion animation primitives for React - scroll reveal, page transitions, animated counters, and more",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "motion": ">=11.0.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "motion": "^12.0.0",
    "react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "react",
    "framer-motion",
    "motion",
    "animation",
    "scroll-reveal",
    "page-transition",
    "animated-counter",
    "hamburger-icon"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/philiprehberger/react-motion-components"
  },
  "sideEffects": false
}
